<?xml version="1.0" encoding="UTF-8"?>
<!-- kiosk openbox config: every window opens undecorated and maximized,
     so the browser's tab strip is the topmost thing on the screen. -->
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <focus>
    <focusNew>yes</focusNew>
  </focus>
  <applications>
    <application class="*">
      <decor>no</decor>
      <maximized>yes</maximized>
    </application>
  </applications>
</openbox_config>
